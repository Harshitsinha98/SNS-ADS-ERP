rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Client rules are a tenant-data boundary. Billing, ownership, membership
    // lifecycle, quotas, and system events are deliberately server-only.
    function signedIn() { return request.auth != null; }
    function memberPath(orgId) {
      return /databases/$(database)/documents/memberships/$(request.auth.uid + '_' + orgId);
    }
    function hasMembership(orgId) { return signedIn() && exists(memberPath(orgId)); }
    function membership(orgId) { return get(memberPath(orgId)).data; }
    function isActiveMember(orgId) {
      return hasMembership(orgId)
        && membership(orgId).active == true
        && (!membership(orgId).keys().hasAll(['expiresAtMs'])
          || membership(orgId).expiresAtMs > request.time.toMillis());
    }
    function hasRole(orgId, role) { return isActiveMember(orgId) && membership(orgId).role == role; }
    function isAdmin(orgId) { return hasRole(orgId, 'owner') || hasRole(orgId, 'admin'); }
    function isPlatformAdmin() {
      return signedIn() && (
        request.auth.token.phone_number == '+919653043939' ||
        exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid))
      );
    }
    function leadPath(orgId, leadId) {
      return /databases/$(database)/documents/organizations/$(orgId)/leads/$(leadId);
    }
    function isLeadAssignee(orgId, leadId) {
      return isActiveMember(orgId) &&
        exists(leadPath(orgId, leadId)) &&
        get(leadPath(orgId, leadId)).data.assignedTo == request.auth.uid;
    }
    // Follow-up lifecycle, lead assignment, terminal status, and SLA timestamps
    // are server-owned so they cannot diverge from the task/audit workflow.
    function employeeLeadFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['priority']);
    }
    // Provider timestamps and entitlement/accounting fields stay server-owned.
    function adminLeadFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['priority']);
    }

    match /platformAdmins/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isPlatformAdmin());
      allow write: if false;
    }

    // Public pricing can be read by the marketing site. Only the platform owner
    // can alter global configuration.
    match /platformConfig/{docId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // The backend atomically records and checks trial usage.
    match /trialsUsed/{phoneKey} {
      allow read, write: if false;
    }

    // Invites and memberships are created/claimed by authenticated backend
    // routes so a client can never alter role, org, or active state.
    match /invites/{inviteId} {
      allow read: if isPlatformAdmin() || (resource != null && isAdmin(resource.data.orgId));
      allow write: if false;
    }

    // WhatsApp routing is verified with Meta and maintained by the backend;
    // browser clients cannot claim a shared provider phone-number ID.
    match /whatsappConfigs/{phoneNumberId} {
      allow read, write: if false;
    }
    match /whatsappCredentials/{orgId} { allow read, write: if false; }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isPlatformAdmin());
      allow write: if false;
    }

    match /memberships/{membershipId} {
      allow read: if signedIn() && (
        request.auth.uid == resource.data.uid ||
        isAdmin(resource.data.orgId) ||
        isPlatformAdmin()
      );
      allow write: if false;
    }

    match /organizations/{orgId} {
      allow read: if isActiveMember(orgId) || isPlatformAdmin();
      allow create, update, delete: if false;

      match /leads/{leadId} {
        // Use `resource` here so Firestore can authorize the employee's
        // `where('assignedTo', '==', request.auth.uid)` collection query.
        allow read: if isAdmin(orgId)
          || (isActiveMember(orgId) && resource.data.assignedTo == request.auth.uid);
        // Backend creates and counts every lead so quotas cannot be bypassed.
        allow create, delete: if false;
        allow update: if (isAdmin(orgId) && adminLeadFieldsOnly())
          || (isActiveMember(orgId)
            && resource.data.assignedTo == request.auth.uid
            && employeeLeadFieldsOnly());

        match /notes/{noteId} {
          allow read: if isAdmin(orgId)
            || (isLeadAssignee(orgId, leadId)
              && resource.data.visibility == 'team'
              && resource.data.type == 'worknote');
          allow create: if (
              isAdmin(orgId)
              && request.resource.data.authorId == request.auth.uid
            ) || (
              isLeadAssignee(orgId, leadId)
              && request.resource.data.authorId == request.auth.uid
              && request.resource.data.visibility == 'team'
            );
          allow update, delete: if false;
        }

        match /private/{docId} {
          allow read, write: if isAdmin(orgId);
        }

        // Provider transcripts are sensitive customer communications and remain
        // visible only to workspace administrators.
        match /messages/{messageId} {
          allow read: if isAdmin(orgId);
          allow write: if false;
        }
      }

      // Follow-up tasks are written, audited, and completed only by the backend.
    // Members can read only their own assignments; admins can oversee all work.
    match /followUpTasks/{taskId} {
      allow read: if isAdmin(orgId)
        || (isActiveMember(orgId) && resource.data.assignedTo == request.auth.uid);
      allow write: if false;
    }
    match /followUpTaskEvents/{eventId} { allow read, write: if false; }

    // Template definitions contain no provider credential. Active members can
    // select only server-synced Meta templates; all writes and sends are backend-only.
    match /whatsappTemplates/{templateId} {
      allow read: if isActiveMember(orgId);
      allow write: if false;
    }

    // WhatsApp connection state is backend-authored. Other settings remain
      // tenant-admin editable through their existing UI.
      match /settings/whatsapp {
        allow read: if isActiveMember(orgId);
        allow write: if false;
      }
      match /settings/{settingsId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId) && settingsId != 'whatsapp';
      }
      match /meta/{metaId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId);
      }
      match /goals/{goalId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId);
      }

      // Activity is a backend-authored audit trail.
      match /activity/{activityId} {
        allow read: if isAdmin(orgId) || isPlatformAdmin();
        allow write: if false;
      }

      match /notifications/{notificationId} {
        allow read: if isActiveMember(orgId) && resource.data.userId == request.auth.uid;
        allow create: if isAdmin(orgId) && request.resource.data.orgId == orgId;
        allow update: if isActiveMember(orgId)
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        allow delete: if false;
      }

      // Queue documents and all billing/invoice data are backend-only.
      match /pending_leads/{pendingId} { allow read, write: if false; }
      match /invoices/{invoiceId} { allow read: if isAdmin(orgId); allow write: if false; }

      // ── Workflow Automation Engine ──
      // Workflow logic (conditions/actions) is Zod-validated and versioned by
      // the backend only. Admins can read the head + version history to power
      // the UI Builder, but every create/edit/publish/rollback goes through
      // the API (workflow.controller.js) so validation can never be bypassed
      // by a direct client write.
      match /workflows/{workflowId} {
        allow read: if isAdmin(orgId) || isPlatformAdmin();
        allow write: if false;

        match /versions/{version} {
          allow read: if isAdmin(orgId) || isPlatformAdmin();
          allow write: if false;
        }
      }

      // Execution audit log — admins can review what a workflow did, but the
      // log itself is exclusively backend-authored (see workflowEngine.js).
      match /workflowRuns/{runId} {
        allow read: if isAdmin(orgId) || isPlatformAdmin();
        allow write: if false;
      }

      // Idempotency claim documents (mirrors whatsappMessageEvents /
      // systemLocks) — purely internal engine state, never client-visible.
      match /workflowTriggerState/{key} { allow read, write: if false; }

      // Tickets follow the same visibility shape as leads: admins see every
      // ticket, an employee sees only tickets assigned to them. All writes
      // are backend-only (ticketService.js) so status transitions always
      // stay consistent with the workflow engine's ticket_closed trigger.
      match /tickets/{ticketId} {
        allow read: if isAdmin(orgId)
          || (isActiveMember(orgId) && resource.data.assignedTo == request.auth.uid);
        allow write: if false;
      }

      // Tags/Products are lightweight admin-configured reference data that
      // power the Workflow Builder's condition-value pickers — same
      // trust level as goals/meta (admin-editable directly, no dedicated
      // backend validation route needed for such low-risk reference data).
      match /tags/{tagId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId);
      }
      match /products/{productId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId);
      }

      // Outbound emails are recorded by the Email action for audit visibility
      // even when no real provider is configured yet (see emailService.js).
      match /emailOutbox/{emailId} {
        allow read: if isAdmin(orgId);
        allow write: if false;
      }
    }

    // Website-integration credentials, public-form settings, and shared rate
    // limiter records are server-only. The browser talks to the backend, never
    // directly to these collections.
    match /websiteLeadKeys/{id} { allow read, write: if false; }
    match /websiteLeadIntegrations/{id} { allow read, write: if false; }
    match /websiteLeadRateLimits/{id} { allow read, write: if false; }
    match /adLeadConnections/{id} { allow read, write: if false; }
    match /adLeadRateLimits/{id} { allow read, write: if false; }
    match /paymentIntents/{id} { allow read, write: if false; }
    match /billingEvents/{id} { allow read, write: if false; }
    match /razorpayWebhookEvents/{id} { allow read, write: if false; }
    match /whatsappMessageEvents/{id} { allow read, write: if false; }
    match /whatsappPendingMessages/{id} { allow read, write: if false; }
    match /whatsappOutboundIntents/{id} { allow read, write: if false; }
    match /whatsappOutboundDispatches/{id} { allow read, write: if false; }
    match /systemLocks/{id} { allow read, write: if false; }
    match /subscriptionIntents/{id} { allow read, write: if false; }
    match /signupSessions/{id} { allow read, write: if false; }
    match /signupSessionRecoveries/{id} { allow read, write: if false; }
    match /leadImports/{id} { allow read, write: if false; }
    match /razorpayPlans/{id} { allow read, write: if false; }

    // ── Collection Group queries ──
    // Platform admin needs collectionGroup("activity") to aggregate events
    // across ALL organizations. Firestore requires a {path=**} rule for
    // collection-group queries; the nested /organizations/{orgId}/activity
    // rule alone is insufficient for cross-tenant scans.
    match /{path=**}/activity/{activityId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }

    // ── Platform Owner Console collections ──
    match /platformAnalytics/{docId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }
    match /platformAuditLogs/{logId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }
    match /platformFeatureFlags/{flagId} {
      allow read: if isPlatformAdmin();
      allow write: if false;
    }
  }
}
