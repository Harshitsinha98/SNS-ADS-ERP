rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPER FUNCTIONS
    // Uses exists() + get().data (short-circuited) — the safe pattern
    // that never errors when a membership document is absent.
    // ============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function membershipPath(orgId) {
      return /databases/$(database)/documents/memberships/$(request.auth.uid)_$(orgId);
    }

    function hasMembershipDoc(orgId) {
      return isAuthenticated() && exists(membershipPath(orgId));
    }

    function memberData(orgId) {
      return get(membershipPath(orgId)).data;
    }

    // Active member of the org (any role)
    function isActiveMember(orgId) {
      return hasMembershipDoc(orgId) && memberData(orgId).active == true;
    }

    function hasRole(orgId, role) {
      return hasMembershipDoc(orgId)
             && memberData(orgId).active == true
             && memberData(orgId).role == role;
    }

    function isAdmin(orgId) {
      return hasRole(orgId, 'admin') || hasRole(orgId, 'owner');
    }

    function isOwner(orgId) {
      return hasRole(orgId, 'owner');
    }

    // ============================================================
    // GLOBAL USER IDENTITY  (users/{uid})
    // ============================================================

    match /users/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if false;
    }

    // ============================================================
    // MEMBERSHIPS  (memberships/{uid}_{orgId})
    // ============================================================

    match /memberships/{membershipId} {
      // A user can read their own membership documents; admins/owners can
      // read all memberships within organizations they manage (Team page).
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.uid ||
        isAdmin(resource.data.orgId)
      );

      // Self-serve signup: a user creates their OWN owner membership.
      // OR an existing admin adds someone else to their org.
      allow create: if isAuthenticated() && (
        (request.resource.data.uid == request.auth.uid &&
         request.resource.data.role == 'owner') ||
        (request.auth.uid != request.resource.data.uid &&
         isAdmin(request.resource.data.orgId))
      );

      // Admin can update memberships in their org; a user can touch their own
      allow update: if isAuthenticated() && (
        isAdmin(resource.data.orgId) ||
        request.auth.uid == resource.data.uid
      );

      // Only owner can remove members
      allow delete: if isAuthenticated() && isOwner(resource.data.orgId);
    }

    // ============================================================
    // ORGANIZATIONS  (organizations/{orgId})
    // ============================================================

    match /organizations/{orgId} {
      // Read: any active member
      allow read: if isActiveMember(orgId);

      // Create: any authenticated user (self-serve signup)
      allow create: if isAuthenticated();

      // Update: admin/owner only
      allow update: if isAdmin(orgId);

      // Delete: disabled (soft-delete preferred)
      allow delete: if false;

      // ----- LEADS -----
      match /leads/{leadId} {
        allow read: if isActiveMember(orgId);
        allow create: if isActiveMember(orgId)
                      && request.resource.data.orgId == orgId;
        allow update: if isAdmin(orgId)
                      || (isActiveMember(orgId)
                          && resource.data.assignedTo == request.auth.uid);
        allow delete: if isAdmin(orgId);

        // Notes on a lead
        match /notes/{noteId} {
          allow read: if isActiveMember(orgId)
                      && (resource.data.visibility == 'team' || isAdmin(orgId));
          allow create: if isActiveMember(orgId);
          allow update: if isActiveMember(orgId)
                        && (isAdmin(orgId) || resource.data.authorId == request.auth.uid);
          allow delete: if isAdmin(orgId);
        }

        // Private financials — admin/owner only
        match /private/{docId} {
          allow read, write: if isAdmin(orgId);
        }
      }

      // ----- SETTINGS -----
      match /settings/{settingsId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId);
      }

      // ----- META (lead assignment counter) -----
      match /meta/{metaId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId);
      }

      // ----- ACTIVITY (immutable audit log) -----
      match /activity/{activityId} {
        allow read: if isActiveMember(orgId);
        allow create: if isActiveMember(orgId)
                      && request.resource.data.orgId == orgId;
        allow update, delete: if false;
      }

      // ----- NOTIFICATIONS -----
      match /notifications/{notifId} {
        allow read: if isActiveMember(orgId)
                    && resource.data.userId == request.auth.uid;
        allow create: if isActiveMember(orgId);
        allow update, delete: if isActiveMember(orgId)
                              && resource.data.userId == request.auth.uid;
      }

      // ----- GOALS -----
      match /goals/{goalsId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId);
      }

      // ----- PENDING LEADS (WhatsApp queue) -----
      match /pending_leads/{pendingId} {
        allow read, write: if isAdmin(orgId);
      }
    }
  }
}
