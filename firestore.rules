rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPERS
    // ============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // Platform super-admin (CodeSkate owner). Marked by a doc in platformAdmins.
    function isPlatformAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid));
    }

    function membershipPath(orgId) {
      return /databases/$(database)/documents/memberships/$(request.auth.uid + '_' + orgId);
    }
    function hasMembershipDoc(orgId) {
      return isAuthenticated() && exists(membershipPath(orgId));
    }
    function memberData(orgId) {
      return get(membershipPath(orgId)).data;
    }
    function isActiveMember(orgId) {
      return hasMembershipDoc(orgId) && memberData(orgId).active == true;
    }
    function hasRole(orgId, role) {
      return hasMembershipDoc(orgId)
             && memberData(orgId).active == true
             && memberData(orgId).role == role;
    }
    function isAdmin(orgId) {
      return hasRole(orgId, 'admin') || hasRole(orgId, 'owner');
    }
    function isOwner(orgId) {
      return hasRole(orgId, 'owner');
    }

    // Org billing helpers (safe .get with defaults)
    function orgData(orgId) {
      return get(/databases/$(database)/documents/organizations/$(orgId)).data;
    }
    function seatAvailable(orgId) {
      let o = orgData(orgId);
      return o.get('seatsUsed', 0) < o.get('seatsLimit', 0);
    }
    // Subscription usable? active plan, OR trialing and not past trialEndsAtMs.
    // If trialEndsAtMs is missing (older orgs created before this field), we
    // give the benefit of the doubt so existing workspaces keep working.
    function subActive(orgId) {
      let o = orgData(orgId);
      let status = o.get('subscriptionStatus', 'trialing');
      return status == 'active'
             || (status == 'trialing'
                 && (o.get('trialEndsAtMs', 0) == 0
                     || o.get('trialEndsAtMs', 0) > request.time.toMillis()));
    }

    // ============================================================
    // PLATFORM (super-admin only)
    // ============================================================

    match /platformAdmins/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isPlatformAdmin());
      allow write: if false; // create manually in console / via admin SDK
    }

    // Global config (trial length, plan limits/prices). Public read so the
    // marketing site can show current pricing/trial; only owner can write.
    match /platformConfig/{docId} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // One free trial per phone number, ever.
    match /trialsUsed/{phoneKey} {
      allow read: if isAuthenticated();
      // Only the owner of the verified phone can record its trial usage.
      allow create: if isAuthenticated()
                    && request.resource.data.phone == request.auth.token.phone_number;
      allow update, delete: if false;
    }

    // ============================================================
    // GLOBAL USER IDENTITY
    // ============================================================

    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isPlatformAdmin());
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if false;
    }

    // ============================================================
    // MEMBERSHIPS
    // ============================================================

    match /memberships/{membershipId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.uid ||
        isAdmin(resource.data.orgId) ||
        isPlatformAdmin()
      );

      // Self-serve signup: own owner membership (no seat/sub gate — first seat).
      // OR admin adds a teammate: must have a free seat AND an active subscription.
      allow create: if isAuthenticated() && (
        (request.resource.data.uid == request.auth.uid &&
         request.resource.data.role == 'owner') ||
        (request.auth.uid != request.resource.data.uid &&
         isAdmin(request.resource.data.orgId) &&
         seatAvailable(request.resource.data.orgId) &&
         subActive(request.resource.data.orgId))
      );

      allow update: if isAuthenticated() && (
        isAdmin(resource.data.orgId) ||
        request.auth.uid == resource.data.uid
      );

      allow delete: if isAuthenticated() && isOwner(resource.data.orgId);
    }

    // ============================================================
    // ORGANIZATIONS
    // ============================================================

    match /organizations/{orgId} {
      // Members read their org; platform admin reads/lists all.
      allow read: if isActiveMember(orgId) || isPlatformAdmin();
      allow create: if isAuthenticated();
      // Admin/owner manage the org (incl. seat counter + plan changes);
      // platform admin can manage any org.
      allow update: if isAdmin(orgId) || isPlatformAdmin();
      allow delete: if false;

      match /leads/{leadId} {
        allow read: if isActiveMember(orgId);
        // New leads require an active subscription/trial.
        allow create: if isActiveMember(orgId)
                      && request.resource.data.orgId == orgId
                      && subActive(orgId);
        allow update: if isAdmin(orgId)
                      || (isActiveMember(orgId) && resource.data.assignedTo == request.auth.uid);
        allow delete: if isAdmin(orgId);

        match /notes/{noteId} {
          allow read: if isActiveMember(orgId) && (resource.data.visibility == 'team' || isAdmin(orgId));
          allow create: if isActiveMember(orgId);
          allow update: if isActiveMember(orgId) && (isAdmin(orgId) || resource.data.authorId == request.auth.uid);
          allow delete: if isAdmin(orgId);
        }
        match /private/{docId} {
          allow read, write: if isAdmin(orgId);
        }
      }

      match /settings/{settingsId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId);
      }
      match /meta/{metaId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId);
      }
      match /activity/{activityId} {
        allow read: if isActiveMember(orgId);
        allow create: if isActiveMember(orgId) && request.resource.data.orgId == orgId;
        allow update, delete: if false;
      }
      match /notifications/{notifId} {
        allow read: if isActiveMember(orgId) && resource.data.userId == request.auth.uid;
        allow create: if isActiveMember(orgId);
        allow update, delete: if isActiveMember(orgId) && resource.data.userId == request.auth.uid;
      }
      match /goals/{goalsId} {
        allow read: if isActiveMember(orgId);
        allow write: if isAdmin(orgId);
      }
      match /pending_leads/{pendingId} {
        allow read, write: if isAdmin(orgId);
      }
    }
  }
}
