# Firebase Configuration
# Get these from Firebase Console > Project Settings > General > Your Apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend base URL (whatsapp-backend) — used for WhatsApp sync AND payments
VITE_BACKEND_URL=https://your-backend-host.com

# WhatsApp number for the public “Talk to sales” link, digits only with country code.
# Defaults to the platform-owner number in code if omitted; set this explicitly in Vercel.
VITE_SALES_WHATSAPP_NUMBER=919653043939

# Razorpay public Key ID (safe for frontend). Secret stays on the backend only.
VITE_RAZORPAY_KEY_ID=rzp_test_TEzlUzUWqGLYNE
