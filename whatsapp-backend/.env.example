# WhatsApp Business API Configuration
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Server Configuration
PORT=3001

# Firebase Admin SDK
# Place your serviceAccountKey.json in this directory

# Multi-Tenant Configuration
DEFAULT_ORG_ID=your_default_organization_id_here

# Instructions:
# 1. Copy this file to .env
# 2. Fill in your WhatsApp Business API credentials
# 3. Get DEFAULT_ORG_ID from the migration script output
# 4. Ensure serviceAccountKey.json is in the same directory (DO NOT commit this file)
