# ---- Backend environment (whatsapp-backend) ----
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

PORT=3001

# Browser origins allowed to call the API (comma-separated). Do not use * in production.
FRONTEND_URL=https://your-frontend.vercel.app
ALLOWED_ORIGINS=https://your-frontend.vercel.app
PUBLIC_BACKEND_URL=https://your-backend-host.com
PLATFORM_OWNER_PHONE=+919653043939

# WhatsApp Cloud API webhooks. VERIFY_TOKEN is used for Meta's GET challenge;
# APP_SECRET is required to validate every POST request signature.
WHATSAPP_VERIFY_TOKEN=your_random_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret

# Meta Embedded Signup and Cloud API. App secret and token encryption key are
# backend-only. Generate the encryption key with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_GRAPH_API_VERSION=v22.0
WHATSAPP_TOKEN_ENCRYPTION_KEY=base64_encoded_32_byte_key

# Firebase Admin credentials are required on Render. Supply either the raw
# service-account JSON or its base64-encoded representation; never use VITE_.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account"}

# ---- Razorpay (popup checkout) ----
# Key ID is public; Key Secret must stay server-side only.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Required for /api/billing/webhook/razorpay signature verification.
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ---- PayU (redirect checkout) ----
PAYU_KEY=your_payu_key
PAYU_SALT=your_payu_salt
PAYU_MODE=test
